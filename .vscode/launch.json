{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug hello_world",
            "cargo": {
                "args": ["build", "--bin=hello_world", "--manifest-path=rsbtc/practice/hello_world/Cargo.toml"],
                "filter": { "name": "hello_world", "kind": "bin" }
            },
            "args": ["reverse", "Hello World"],
            "cwd": "${workspaceRoot}"
        },
